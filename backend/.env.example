# Stellar KYC Backend Environment Variables
# Copy to .env and fill in values

# Server
NODE_ENV=development
PORT=3001
LOG_LEVEL=info

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stellar_kyc
DB_USER=postgres
DB_PASSWORD=your_secure_password
DB_SSL=false

# Redis (for consent token caching)
REDIS_URL=redis://localhost:6379

# Stellar
ANCHOR_DID=did:stellar:GANCHOR_PLATFORM_ADDRESS
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org

# Credential Settings
CREDENTIAL_EXPIRY_DAYS=365

# CORS
CORS_ORIGIN=http://localhost:3000,https://app.stellarkyc.org

# KYC Providers (API Keys)
DIGILOCKER_CLIENT_ID=your_digilocker_client_id
DIGILOCKER_CLIENT_SECRET=your_digilocker_secret
PHILSYS_API_KEY=your_philsys_key
SMILE_ID_PARTNER_ID=your_smile_id_partner_id
SMILE_ID_API_KEY=your_smile_id_key
TRULIOO_API_KEY=your_trulioo_key
ONFIDO_API_TOKEN=your_onfido_token
JUMIO_API_TOKEN=your_jumio_token
JUMIO_API_SECRET=your_jumio_secret

# AWS (for face matching)
AWS_ACCESS_KEY_ID=your_aws_key
AWS_SECRET_ACCESS_KEY=your_aws_secret
AWS_REGION=us-east-1

# IPFS (for credential hashes)
IPFS_GATEWAY=https://ipfs.io/ipfs/

# Security
JWT_SECRET=your_jwt_secret_min_32_chars
ENCRYPTION_KEY=your_encryption_key_32_chars

# Monitoring
SENTRY_DSN=https://your_sentry_dsn
